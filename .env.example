# ─── Database (Neon) ──────────────────────────────────────────
# Pooled connection (via PgBouncer) for the app
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.eu-central-1.aws.neon.tech/quickfood?sslmode=require&pgbouncer=true
# Direct connection for prisma migrate
DIRECT_URL=postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/quickfood?sslmode=require

# ─── Auth ─────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=replace-me-with-48-bytes-of-base64-randomness-or-better

# ─── Cloudflare R2 ────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=quickfood-uploads
R2_PUBLIC_URL=https://cdn.quickfood.app

# ─── SMS provider (MVP: console) ──────────────────────────────
# Options: console | sms4free | twilio
SMS_PROVIDER=console

# ─── Payment provider: Grow (formerly Meshulam) ───────────────
# Docs: https://grow-il.readme.io
# GROW_API_URL is informational; the provider auto-picks sandbox/prod from
# PaymentProviderConfig.testMode (per tenant).
GROW_API_URL=https://sandbox.meshulam.co.il/api/light/server/1.0
# Platform-level apiKey - sent as body param on every call + as X-API-KEY
# header on /createPaymentProcess.
GROW_API_KEY=
# Platform-level default pageCode (must be configured for SDK Wallet mode in
# Grow's backend). Per-tenant override possible via credentials.pageCode.
GROW_PAGE_CODE=
# Optional: platform commission per transaction (₪, excl. VAT - NOT percent).
GROW_COMPANY_COMMISSION=
# Optional: force SDK env on the client. Defaults to DEV in non-prod builds.
# Values: DEV | PRODUCTION
NEXT_PUBLIC_GROW_ENV=

# ─── Vercel Cron secret ───────────────────────────────────────
CRON_SECRET=

# ─── Vercel Domains API (per-tenant custom domain flow) ───────
# Personal access token with scope on the QuickFood project.
# Create at https://vercel.com/account/tokens.
VERCEL_TOKEN=
# Project + team identifiers - copy from .vercel/project.json.
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# ─── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Web Push (couriers) - generate via "npx web-push generate-vapid-keys"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:owner@example.com

# ─── Loyalty club mailing (Poply) ─────────────────────────────
# Poply is our own email+SMS marketing platform (the `poplynext` project).
# QuickFood uses one platform-level key scoped `quickfood_live_*`.
POPLY_API_URL=
POPLY_API_KEY=
# QuickFood's verified sender address inside Poply. Loyalty emails send as
# "<business name> <POPLY_FROM_EMAIL>" so the display name is the merchant's
# over our verified domain. Unset = Poply workspace default sender.
POPLY_FROM_EMAIL=
# Mailing to club members stays gated until paid mailing packages ship.
# Set to "true" to enable real sends from the loyalty dashboard.
LOYALTY_MAILING_ENABLED=

# ─── Meta Pixel + Conversions API (marketing) ─────────────────
# Pixel ID is public (also has a hardcoded fallback in lib/fb/config.ts)
NEXT_PUBLIC_FB_PIXEL_ID=1698088694710365
# CAPI access token - SECRET. Events Manager > QuickFood dataset > Settings > Conversions API > Generate access token
FB_CAPI_ACCESS_TOKEN=
# Optional: paste a test_event_code while verifying in Events Manager > Test Events
FB_CAPI_TEST_EVENT_CODE=

# ─── Menu import (AI) ──────────────────────────────────────────
# Platform-level Gemini key used to extract menus from uploaded PDFs/images
# (the "ייבוא מ-PDF" flow). ~6 agorot per menu, billed to the platform. If
# unset, the import falls back to the tenant's own configured Gemini key,
# and is disabled for tenants without one.
GEMINI_API_KEY=
# Optional model override (default gemini-2.5-flash). Shared with the AI advisor.
GEMINI_MODEL=gemini-2.5-flash

# ─── Google Analytics 4 (marketing) ───────────────────────────
# Measurement ID is public (also has a hardcoded fallback in lib/ga/config.ts)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-FPW4ZGJ57E
