// QuickFood - Prisma schema
// מקור האמת: /Users/tadmitinteractive/Downloads/pizza/DATA_MODEL.md
// תוספות מהתכנית: WebhookEndpoint, WebhookDelivery, ApiKey, OrderEvent, OtpCode

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ──────────────────────────────────────────────────────

enum TenantStatus {
  active
  suspended
  trial
}

enum CustomDomainStatus {
  none
  pending
  active
  error
}

enum ThemeId {
  fresh
  basil
  forest
  olive
  tomato
  charcoal
  cobalt
  sunflower
  apricot
}

enum RestaurantStatus {
  open
  busy
  closed
}

enum OrderStatus {
  pending
  confirmed
  preparing
  in_oven
  ready
  out_for_delivery
  delivered
  cancelled
  refunded
}

enum OrderMethod {
  delivery
  pickup
}

enum PaymentMethod {
  card
  cash
  apple_pay
  google_pay
  bit
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

/// How the order itself was initiated. `direct` is the default -
/// customer browsed the menu and built a cart manually. Other values
/// power the merchant analytics breakdown of channel performance.
enum OrderSource {
  direct
  ai_advisor
  reorder
  kiosk
  pos
  wolt
}

/// How a specific line landed in the cart. A single order can mix
/// sources - e.g. an AI-driven cart with one upsell line added later.
/// The Order.source above is the dominant flow at order-placement
/// time; this is per-line provenance.
enum OrderItemSource {
  menu
  ai_advisor
  upsell
  reorder
  wolt
}

enum CourierStatus {
  available
  on_delivery
  break_time
  offline
}

enum CourierVehicle {
  scooter
  bike
  car
  walking
}

enum UserRole {
  owner
  manager
  kitchen
  courier_dispatch
  platform_admin
  cashier
}

enum SubscriptionStatus {
  trial
  active
  past_due
  cancelled
}

enum OptionGroupType {
  single
  multi
}

enum WoltImportStatus {
  preview   // Menu fetched + parsed, raw JSON cached, awaiting merchant confirmation
  committed // Successfully imported into the tenant's menu
  failed    // Aborted mid-commit; `errors` holds the breakdown
}

enum CouponType {
  percent
  fixed
}

enum CouponAppliesTo {
  all
  category
  items
}

enum ReviewChannel {
  off
  email
  sms
  whatsapp
  whatsapp_managed
}

enum NotificationStatus {
  pending
  sent
  delivered
  failed
  skipped_no_balance
  invalid_recipient
}

enum ReviewStatus {
  visible
  hidden
  flagged
}

enum RecipientType {
  customer
  merchant_user
}

enum WebhookDeliveryStatus {
  pending
  success
  failed
  abandoned
}

enum PaymentProvider {
  cash
  grow
}

enum AIProvider {
  gemini
  claude
}

enum NoticeScope {
  store
  category
  item
}

enum NoticeKind {
  info
  warning
  allergen
  kosher
  dietary
}

enum BusinessType {
  pizza
  burger
  falafel
  shawarma
  sushi
  asian
  bakery
  cafe
  icecream
  mediterranean
  general
}

enum PendingPaymentStatus {
  pending
  confirmed
  failed
  expired
  cancelled
}

enum PaymentTransactionStatus {
  success
  failed
  refunded
  partially_refunded
}

// ─── Tenant & Branches ──────────────────────────────────────────

model Tenant {
  id                   String         @id @default(uuid()) @db.Uuid
  slug                 String         @unique
  name                 String
  logoLetter           String         @map("logo_letter") @db.VarChar(2)
  logoUrl              String?        @map("logo_url")
  coverImage           String?        @map("cover_image")
  themeId              ThemeId        @default(fresh) @map("theme_id")
  businessType         BusinessType   @default(general) @map("business_type")
  cuisineType          String?        @map("cuisine_type")
  /// Free-text "about" / tagline for the venue. Shown to customers on
  /// the storefront under the venue name, editable from Branding.
  /// Populated by the Wolt importer from the venue description.
  about                String?        @db.Text
  vatNumber            String?        @map("vat_number")
  /// Merchant-editable storefront legal terms (תקנון). When null the
  /// storefront renders an auto-generated default built from the business
  /// details. Required for Grow payment-processor compliance.
  termsText            String?        @db.Text @map("terms_text")
  /// When the merchant explicitly reviewed + approved their storefront terms.
  /// The dashboard hard-blocks until this is set: the merchant must open the
  /// terms editor and accept responsibility for the content (shifts content
  /// liability away from the platform).
  termsAcknowledgedAt  DateTime?      @map("terms_acknowledged_at")
  status               TenantStatus   @default(active)
  planId               String?        @map("plan_id") @db.Uuid
  plan                 Plan?          @relation(fields: [planId], references: [id])
  customDomain         String?        @unique @map("custom_domain")
  customDomainStatus   CustomDomainStatus @default(none) @map("custom_domain_status")
  customDomainVerification Json?      @map("custom_domain_verification")
  customDomainConfig   Json?          @map("custom_domain_config")
  customDomainAddedAt  DateTime?      @map("custom_domain_added_at")
  customDomainVerifiedAt DateTime?    @map("custom_domain_verified_at")
  customDomainLastError String?       @map("custom_domain_last_error")
  acceptsCash          Boolean        @default(true) @map("accepts_cash")
  /// Which payment method should be pre-selected for the customer at
  /// checkout. NULL means "fall back to the platform default order"
  /// (first allowed from cash → card → bit → apple_pay → google_pay).
  /// Server validates the value is currently in the tenant's allowed
  /// methods on every PATCH.
  defaultPaymentMethod PaymentMethod? @map("default_payment_method")
  allowedOrigins       String[]       @default([]) @map("allowed_origins")

  // Checkout configuration. When true (default) the post-order screen renders
  // the live order tracking (ETA, status timeline, SSE updates, branch
  // contact). Merchants can opt out in Settings → Checkout, leaving a simple
  // e-commerce "thank you" receipt.
  checkoutShowTracking Boolean @default(true) @map("checkout_show_tracking")

  // When false, the customer can only order "as soon as possible" - the
  // schedule-for-later section is hidden from checkout. Useful for fast-food
  // spots that don't want pre-orders piling up in the queue.
  scheduledOrdersEnabled Boolean @default(true) @map("scheduled_orders_enabled")

  pickupEnabled   Boolean @default(true) @map("pickup_enabled")

  cutleryEnabled    Boolean @default(false) @map("cutlery_enabled")
  cutleryLabel      String  @default("סכו״ם חד״פ") @map("cutlery_label")
  cutleryPrice      Int     @default(0) @map("cutlery_price")
  cutleryFreeAbove  Int?    @map("cutlery_free_above")

  // Monotonic per-tenant order counter. Used by orders-create to assign
  // sequential numbers (M-1, M-2, M-3...) instead of the legacy random
  // 4-digit suffix, which made the Kanban look like the numbers had no
  // relation to each other (M-1771 next to M-2575). Backfilled at
  // migration time to (existing order count + 1) so the merchant's
  // first new order picks up from where their history left off.
  nextOrderNumber Int @default(1) @map("next_order_number")

  // Sales / merchandising knobs.
  //
  // featuredBadgeLabel: text shown on the corner of menu cards that
  // have MenuItem.featured=true. Lets each venue speak in their own
  // voice - "מומלץ של השף" / "הכי נמכר" / "חדש" / etc. NULL falls
  // back to the platform default in the UI.
  featuredBadgeLabel String? @map("featured_badge_label") @db.VarChar(40)
  // upsellSizeNudge: shows a prominent "upgrade to XL for ₪10" banner
  // in the item picker when a larger size exists. Off → sizes render
  // as a plain selector with no extra prompt.
  upsellSizeNudge Boolean @default(true) @map("upsell_size_nudge")

  // Self-service kiosk mode (paid add-on). Toggled per-tenant from
  // the super-admin UI for now; the merchant-side settings page (welcome
  // text, idle reset) is hidden until this flag is on. The kiosk URL is
  // /s/<slug>/kiosk and 404s if false.
  kioskEnabled     Boolean @default(false) @map("kiosk_enabled")
  // Free-text headline shown on the kiosk's start screen above the
  // "tap to order" CTA. NULL falls back to "ברוכים הבאים ל-<name>".
  kioskWelcomeText String? @map("kiosk_welcome_text") @db.VarChar(160)
  // After this many seconds of zero user input the kiosk resets the
  // cart and goes back to the start screen, so the next customer
  // doesn't walk up to someone else's half-built order.
  kioskIdleSeconds Int @default(90) @map("kiosk_idle_seconds")
  /// When false, the kiosk skips the phone-entry screen entirely -
  /// customer goes straight from mode pick to the menu, no OTP, no
  /// invoice prompt. Useful for fast-counter setups where the merchant
  /// doesn't want to slow customers down with a contact field.
  kioskCollectPhone Boolean @default(true) @map("kiosk_collect_phone")
  /// When true, the kiosk requires the customer to enter a phone number
  /// at the start and a name at checkout. We then SMS/WhatsApp the
  /// invoice and link the order to the matching Customer row.
  /// Only meaningful when kioskCollectPhone is true.
  kioskRequirePhone Boolean @default(false) @map("kiosk_require_phone")
  /// Per-tenant string overrides for the kiosk UI. Flat dotted keys
  /// (e.g. "thanks.paidViaQrHeading") map to custom Hebrew strings the
  /// merchant typed in Settings → Kiosk → Custom Strings. Anything
  /// missing falls back to the default in `lib/i18n/kiosk-messages.ts`.
  /// Empty object = use defaults everywhere.
  kioskStringOverrides Json @default("{}") @map("kiosk_string_overrides")

  // Stamped when the merchant clicks any choice on the first-login
  // welcome overlay (start-from-scratch, import-from-wolt, or "later").
  // NULL = overlay hasn't been seen yet → show it on next dashboard visit.
  onboardingDismissedAt DateTime? @map("onboarding_dismissed_at")

  // Which dashboard skin to render. "v2" = the bold yellow/black
  // landing-page brand language (default for all tenants). "v1" =
  // the original green/white chrome. Switchable from Settings →
  // Advanced → Appearance.
  dashboardVersion String @default("v2") @map("dashboard_version") @db.VarChar(10)

  // Receipt printer family for the orders dashboard print button.
  // airprint = OS print dialog (window.print), star = Star PassPRNT app,
  // epson = Epson TM Print Assistant app, escpos = generic Bluetooth
  // ESC/POS printer via the RawBT Android app.
  receiptPrinter String @default("airprint") @map("receipt_printer") @db.VarChar(10)

  // What to print on the receipt. JSON of booleans (show_customer_name,
  // show_customer_phone, show_options, show_option_prices, show_item_notes,
  // show_order_notes). Empty default = every section on; resolveReceiptSettings
  // fills missing keys as true so older tenants keep the full receipt.
  receiptSettings Json @default("{}") @map("receipt_settings")

  // Reviews configuration
  reviewsEnabled      Boolean       @default(true) @map("reviews_enabled")
  reviewsPublic       Boolean       @default(true) @map("reviews_public")
  reviewsChannel      ReviewChannel @default(email) @map("reviews_channel")
  reviewsDelayMinutes Int           @default(60) @map("reviews_delay_minutes")
  // Channel for transactional order notifications (confirmed / ready / on-the-way
  // / delivered). Sent IN ADDITION to the always-on email. Same resolution as
  // reviewsChannel: sms + own/default WhatsApp draw the credit pool;
  // whatsapp_managed uses the platform iBot account. `email`/`off` = no paid send.
  notifyChannel       ReviewChannel @default(email) @map("notify_channel")
  smsSender           String?       @map("sms_sender") @db.VarChar(11)

  // SMS + WhatsApp credit balance. Top-ups (Starter/Growth/Scale) STACK -
  // there is no messaging subscription. Each purchase is a one-off charge
  // to the saved token that adds the package quota to this counter. Both
  // SMS and WhatsApp sends decrement from the same pool because per-message
  // price is the same.
  smsCreditsRemaining Int @default(0) @map("sms_credits_remaining")

  // iBot Chat (WhatsApp) credentials. Each tenant connects their own iBot
  // instance - QuickFood does not host a shared WhatsApp number. When both
  // fields are set we treat WhatsApp as available; the `reviewsChannel`
  // value `whatsapp` triggers sends.
  whatsappToken      String? @map("whatsapp_token")
  whatsappInstanceId String? @map("whatsapp_instance_id")

  aiAdvisorEnabled      Boolean    @default(false) @map("ai_advisor_enabled")
  aiAdvisorPopupEnabled Boolean    @default(false) @map("ai_advisor_popup_enabled")
  aiAdvisorSuggestions  String[]   @default([]) @map("ai_advisor_suggestions")
  aiProvider            AIProvider @default(gemini) @map("ai_provider")
  aiGeminiApiKey        String?    @map("ai_gemini_api_key")
  aiClaudeApiKey        String?    @map("ai_claude_api_key")

  // Mirror IDs from the QuickBilling Hub (canonical state lives there).
  billingCustomerId       String?   @map("billing_customer_id")
  // Base platform subscription (quickfood_base - ₪299/mo + VAT).
  billingSubscriptionId   String?   @map("billing_subscription_id")
  // Managed-WhatsApp reviews add-on (quickfood_reviews_whatsapp - ₪99/mo + VAT,
  // unlimited sends via the platform iBot account). Mirrored from the hub on
  // subscription.created / .cancelled webhooks. When set, reviewsChannel may be
  // `whatsapp_managed`; sends bypass the smsCreditsRemaining pool.
  reviewsWhatsappSubscriptionId String? @map("reviews_whatsapp_subscription_id")
  billingPaymentMethodId  String?   @map("billing_payment_method_id")
  // Set when the merchant has completed billing setup (token saved). Until
  // then SMS purchases are blocked and after `trialEndsAt` the whole
  // dashboard is locked behind a "complete payment" screen.
  billingSetupCompletedAt DateTime? @map("billing_setup_completed_at")
  // 7-day local trial countdown set at signup. After this date, without a
  // saved payment method, the dashboard is fully locked.
  trialEndsAt             DateTime? @map("trial_ends_at")

  // Meta click/browser ids captured from the _fbp/_fbc cookies at signup.
  // Reused when the merchant later pays so the server-side Purchase event
  // (fired from the billing webhook, which has no browser context) can be
  // matched back to the same person who fired CompleteRegistration.
  fbp                     String?   @map("fb_fbp")
  fbc                     String?   @map("fb_fbc")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  branches         Branch[]
  menuCategories   MenuCategory[]
  menuItems        MenuItem[]
  bundleOffers     BundleOffer[]
  coupons          Coupon[]
  merchantUsers    MerchantUser[]
  subscription     Subscription?
  orders           Order[]
  couriers         Courier[]
  cashSettlements  CashSettlement[]
  reviews          Review[]
  webhookEndpoints WebhookEndpoint[]
  apiKeys          ApiKey[]
  idempotencyRecords IdempotencyRecord[]
  paymentConfigs   PaymentProviderConfig[]
  pendingPayments  PendingPayment[]
  kioskCheckouts   KioskPendingCheckout[]
  paymentTxns      PaymentTransaction[]
  campaigns        Campaign[]
  notices          Notice[]
  smsLogs          SmsLog[]
  emailLogs        EmailLog[]
  modifierSets     ModifierSet[]
  woltImports      WoltImport[]
  menuFileImports  MenuFileImport[]
  storefrontVisits StorefrontVisit[]
  woltConnections  WoltConnection[]
  growLeads        GrowLead[]
  posShifts        PosShift[]

  @@index([slug])
  @@map("tenants")
}

model Branch {
  id          String           @id @default(uuid()) @db.Uuid
  tenantId    String           @map("tenant_id") @db.Uuid
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  address     String
  lat         Decimal?         @db.Decimal(10, 7)
  lng         Decimal?         @db.Decimal(10, 7)
  phone       String
  email       String?
  isPrimary   Boolean          @default(false) @map("is_primary")
  status      RestaurantStatus @default(open)
  // Minutes added to every ETA when status == busy. Customer-facing
  // displays surface "+N דק' (עומס)" and the busy-alert modal warns the
  // customer at entry + before checkout.
  busyEtaBoostMinutes Int      @default(15) @map("busy_eta_boost_minutes")
  // Default delivery ETA range (minutes) shown in the store header when no
  // delivery zone defines its own min/max. Editable in branding settings.
  defaultEtaMin Int            @default(25) @map("default_eta_min")
  defaultEtaMax Int            @default(35) @map("default_eta_max")
  hours       Json             @default("{}")
  minOrder    Int              @default(0) @map("min_order")
  deliveryFee Int              @default(0) @map("delivery_fee")
  serviceFee  Int              @default(0) @map("service_fee")
  // Free delivery thresholds. When set (>0) and the cart meets EITHER
  // condition, the delivery fee is waived. Null/0 = that rule is off.
  freeDeliveryMinOrder Int?     @map("free_delivery_min_order")
  freeDeliveryMinItems Int?     @map("free_delivery_min_items")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  zones    DeliveryZone[]
  couriers Courier[]
  orders   Order[]
  cashiers MerchantUser[] @relation("MerchantUserBranch")
  posShifts PosShift[]

  @@index([tenantId])
  @@map("branches")
}

model DeliveryZone {
  id          String   @id @default(uuid()) @db.Uuid
  branchId    String   @map("branch_id") @db.Uuid
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name        String
  radiusKm    Decimal? @map("radius_km") @db.Decimal(6, 2)
  geometry    Json?
  /// Cities this zone delivers to. Single source of truth for the
  /// customer-facing "select your city" picker on the storefront -
  /// the union of all active zones' cities is the supported set.
  /// Stored as plain strings (Hebrew city names) so merchants can
  /// type freely; the picker also offers a curated suggestion list.
  cities      String[] @default([])
  deliveryFee Int      @map("delivery_fee")
  // Per-zone minimum order (shekels); 0 = no minimum. Overrides the
  // branch-level floor when the order resolves to this zone.
  minOrder    Int      @default(0) @map("min_order")
  // Per-zone free-delivery threshold (shekels); NULL/0 = off.
  freeDeliveryAbove Int? @map("free_delivery_above")
  minEta      Int      @map("min_eta")
  maxEta      Int      @map("max_eta")
  active      Boolean  @default(true)

  @@index([branchId])
  @@map("delivery_zones")
}

// ─── Menu ───────────────────────────────────────────────────────

model MenuCategory {
  id       String  @id @default(uuid()) @db.Uuid
  tenantId String  @map("tenant_id") @db.Uuid
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name     String
  icon     String?
  color    String?
  position Int     @default(0)
  active   Boolean @default(true)

  // When true, items from this category are surfaced as the cart-page
  // upsell carousel ("מומלץ עבורך"). Merchants typically flag drinks /
  // sides / desserts. If no category is flagged we fall back to a
  // name-based heuristic at read time.
  upsellInCart Boolean @default(false) @map("upsell_in_cart")

  // When true, items from this category trigger the "want to add a
  // dessert?" interstitial right before the customer hits "place
  // order" (kiosk + storefront checkout). Distinct from upsellInCart
  // - that one shows continuously inside the open cart sheet; this
  // one is a one-shot last-chance prompt the customer either accepts
  // or skips through.
  upsellBeforeCheckout Boolean @default(false) @map("upsell_before_checkout")

  // Provenance for bulk imports (Wolt / CSV / future POS sync). Lets a
  // re-import find the matching local row and update it instead of
  // creating a duplicate. NULL on either side = manually created.
  externalSource String? @map("external_source") @db.VarChar(20)
  externalId     String? @map("external_id") @db.VarChar(64)

  items    MenuItem[]
  notices  Notice[]

  @@unique([tenantId, externalSource, externalId])
  @@index([tenantId, position])
  @@map("menu_categories")
}

model MenuItem {
  id          String       @id @default(uuid()) @db.Uuid
  tenantId    String       @map("tenant_id") @db.Uuid
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId  String       @map("category_id") @db.Uuid
  category    MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  name        String
  description String       @default("")
  imageUrl    String?      @map("image_url")
  images      String[]     @default([])
  artType     String?      @map("art_type")
  basePrice   Int          @map("base_price")
  prepMinutes Int          @default(10) @map("prep_minutes")
  available   Boolean      @default(true)
  featured    Boolean      @default(false)
  position    Int          @default(0)
  tags        String[]     @default([])
  sku         String?
  // Optional time-of-day windowing - minutes since midnight in the local
  // timezone. NULL on either side = no restriction; both set = visible
  // only when the current time is in [from, to). availableDays is a 7-bit
  // mask (bit 0 = Sunday, bit 6 = Saturday); NULL = every day.
  availableFrom Int?       @map("available_from")
  availableTo   Int?       @map("available_to")
  availableDays Int?       @map("available_days")
  // Inventory: if non-null the item auto-disappears when this hits 0.
  // Refilled manually (or via API) when the merchant restocks.
  stockRemaining Int?      @map("stock_remaining")
  // Provenance for bulk imports - see MenuCategory.externalSource for the
  // contract. A re-import keys off (tenantId, externalSource, externalId)
  // to upsert rather than duplicate.
  externalSource String? @map("external_source") @db.VarChar(20)
  externalId     String? @map("external_id") @db.VarChar(64)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  sizes        ItemSize[]
  optionGroups ItemOptionGroup[]
  orderItems   OrderItem[]
  reviewItems  ReviewItem[]
  favoritedBy  Favorite[]
  notices      Notice[]
  bundleTriggers BundleOfferTrigger[]
  bundleAddons   BundleOfferAddon[]
  bundleLinkedFor BundleOffer[] @relation("BundleLinkedItem")

  @@unique([tenantId, externalSource, externalId])
  @@index([tenantId, categoryId, position])
  @@index([tenantId, available])
  @@map("menu_items")
}

/// Suggested combos. When the cart contains at least one item from
/// `triggers` AND none of the `addons`, the customer sees an offer
/// "add X + Y for ₪Z" - accepting injects each addon as its own cart
/// line + an Order.discount line equal to (sum of addon basePrice -
/// bundlePrice) so the merchant sees the savings reflected explicitly
/// on the receipt + the kitchen sees normal items.
///
/// Modelled as additive (the trigger stays in the cart at full price;
/// the bundle just opens up an extra discounted attach) - that's the
/// simpler mental model and lets one customer combine multiple
/// bundles. Replacing bundles (remove the trigger, add the package)
/// were considered but rejected: too easy to surprise a customer who
/// already configured a specific item.
model BundleOffer {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  imageUrl    String?  @map("image_url")
  bundlePrice Int      @map("bundle_price")
  active      Boolean  @default(true)
  position    Int      @default(0)
  // Optional time window - both NULL = always active when active=true.
  validFrom   DateTime? @map("valid_from")
  validUntil  DateTime? @map("valid_until")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  /// Wolt-style upgrade target: the existing combo menu item the
  /// suggestion points at. When the customer's cart contains a trigger
  /// item, the offer surfaces as "שדרג ל-{linkedItem.name}, חוסכים X₪"
  /// and tapping opens the combo's normal ItemDetail (with its own
  /// modifier groups - drink choice, size, etc.). On accept the
  /// customer-side flow swaps the trigger items out for the combo so
  /// the cart doesn't double up. Nullable for backward compatibility
  /// with legacy bundles that pre-pick addons via the `addons` relation;
  /// new bundles must set this and skip the addon list.
  linkedItemId String?    @map("linked_item_id") @db.Uuid
  linkedItem   MenuItem?  @relation("BundleLinkedItem", fields: [linkedItemId], references: [id], onDelete: SetNull)

  triggers BundleOfferTrigger[]
  addons   BundleOfferAddon[]

  @@index([tenantId, active])
  @@map("bundle_offers")
}

/// One of the items whose presence in the cart fires the offer. Cart
/// only needs to contain ONE of these (OR-logic) - most bundles are
/// "if you have a pizza, add chips+drink for ₪15".
model BundleOfferTrigger {
  bundleId String      @map("bundle_id") @db.Uuid
  bundle   BundleOffer @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  itemId   String      @map("item_id") @db.Uuid
  item     MenuItem    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  @@id([bundleId, itemId])
  @@map("bundle_offer_triggers")
}

/// Items that get added when the customer accepts the offer.
/// `qty` lets the same item appear N times in one bundle (e.g.
/// "2 cans of Coke" - qty=2 on a single addon row).
model BundleOfferAddon {
  bundleId String      @map("bundle_id") @db.Uuid
  bundle   BundleOffer @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  itemId   String      @map("item_id") @db.Uuid
  item     MenuItem    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  qty      Int         @default(1)
  @@id([bundleId, itemId])
  @@map("bundle_offer_addons")
}

/// Customer "heart" on a menu item - single global favorites list per
/// customer (cross-tenant is fine since one customer eats at multiple
/// restaurants). Composite PK (customerId, itemId) prevents duplicates and
/// makes the "toggle" call a simple upsert.
model Favorite {
  customerId String @map("customer_id") @db.Uuid
  itemId     String @map("item_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  item     MenuItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([customerId, itemId])
  @@index([customerId])
  @@index([itemId])
  @@map("favorites")
}

model ItemSize {
  id         String   @id @default(uuid()) @db.Uuid
  itemId     String   @map("item_id") @db.Uuid
  item       MenuItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  code       String   @db.VarChar(4)
  name       String
  priceDelta Int      @default(0) @map("price_delta")
  isDefault  Boolean  @default(false) @map("is_default")
  position   Int      @default(0)

  @@index([itemId, position])
  @@map("item_sizes")
}

model ItemOptionGroup {
  id            String          @id @default(uuid()) @db.Uuid
  itemId        String          @map("item_id") @db.Uuid
  item          MenuItem        @relation(fields: [itemId], references: [id], onDelete: Cascade)
  name          String
  type          OptionGroupType @default(single)
  required      Boolean         @default(false)
  minSelect     Int             @default(0) @map("min_select")
  maxSelect     Int             @default(1) @map("max_select")
  // Number of selections that are included in the base price (multi-select
  // only). Selections beyond this count add their priceDelta. Default 0 =
  // every selection adds its delta (existing behaviour).
  includedFree  Int             @default(0) @map("included_free")
  helpText      String?         @map("help_text")
  position      Int             @default(0)
  allowHalf     Boolean         @default(false) @map("allow_half")
  // Per-side cap for allowHalf groups. NULL = use maxSelect as a single
  // global cap (legacy). Non-null = each half has its own independent
  // budget of N toppings; "full" placements count toward BOTH sides.
  maxPerSide    Int?            @map("max_per_side")
  // When a half/half placement should also halve the topping's price.
  // false (default) = a topping costs its full priceDelta whether placed on
  // a half or the whole pie ("אין דבר כזה 2.5"). true = legacy behaviour
  // where a half placement charges half the priceDelta.
  splitPrice    Boolean         @default(false) @map("split_price")
  // Third half-pricing mode: when true, a half placement charges the option's
  // explicit `halfPriceDelta` (X) instead of deriving from priceDelta (Y).
  // Wins over splitPrice. The 3-way editor maps: full=(both false),
  // half=(splitPrice), custom=(customHalfPrice).
  customHalfPrice Boolean       @default(false) @map("custom_half_price")
  // Bundle deal: the first `bundleCount` paid selections together cost a flat
  // `bundlePrice` (shekels); selections beyond that pay full price. 0 = off.
  // E.g. bundleCount=2, bundlePrice=5 → "2 תוספות ב-5₪". Independent of
  // includedFree (bundle wins when set).
  bundleCount   Int             @default(0) @map("bundle_count")
  bundlePrice   Int             @default(0) @map("bundle_price")
  // When set, this group inherits its options + config from a ModifierSet.
  // Inline `options` rows are ignored when templateSetId is non-null.
  templateSetId String?         @map("template_set_id") @db.Uuid
  templateSet   ModifierSet?    @relation(fields: [templateSetId], references: [id], onDelete: SetNull)

  options ItemOption[]

  @@index([itemId])
  @@index([templateSetId])
  @@map("item_option_groups")
}

model ItemOption {
  id         String          @id @default(uuid()) @db.Uuid
  groupId    String          @map("group_id") @db.Uuid
  group      ItemOptionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name       String
  priceDelta Int             @default(0) @map("price_delta")
  // Explicit price (shekels) when this option is placed on a single half, used
  // only when the parent group has customHalfPrice=true. NULL falls back to
  // priceDelta.
  halfPriceDelta Int?         @map("half_price_delta")
  isDefault  Boolean         @default(false) @map("is_default")
  available  Boolean         @default(true)
  imageUrl   String?         @map("image_url")
  position   Int             @default(0)

  @@index([groupId, position])
  @@map("item_options")
}

// Reusable option group ("modifier set") - the Wolt-style library that lets a
// merchant define a set of toppings/extras once and attach it to many items.
// Attached via ItemOptionGroup.templateSetId; edits to the set propagate to
// every item that references it.
model ModifierSet {
  id           String          @id @default(uuid()) @db.Uuid
  tenantId     String          @map("tenant_id") @db.Uuid
  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  type         OptionGroupType @default(multi)
  required     Boolean         @default(false)
  minSelect    Int             @default(0) @map("min_select")
  maxSelect    Int             @default(5) @map("max_select")
  includedFree Int             @default(0) @map("included_free")
  helpText     String?         @map("help_text")
  position     Int             @default(0)
  // Catalog-level default for the half-and-half behavior. Propagated to
  // attached ItemOptionGroups on save. See ItemOptionGroup.allowHalf.
  allowHalf    Boolean         @default(false) @map("allow_half")
  // Per-side cap inherited by attached ItemOptionGroups (when they don't
  // override). See ItemOptionGroup.maxPerSide for semantics.
  maxPerSide   Int?            @map("max_per_side")
  // Catalog default for splitPrice on attached groups. See
  // ItemOptionGroup.splitPrice.
  splitPrice   Boolean         @default(false) @map("split_price")
  // Catalog default for customHalfPrice on attached groups. See
  // ItemOptionGroup.customHalfPrice.
  customHalfPrice Boolean      @default(false) @map("custom_half_price")
  // Catalog default for the bundle deal on attached groups. See
  // ItemOptionGroup.bundleCount / bundlePrice.
  bundleCount  Int             @default(0) @map("bundle_count")
  bundlePrice  Int             @default(0) @map("bundle_price")
  // Provenance for bulk imports - see MenuCategory.externalSource. A
  // re-import keys off (tenantId, externalSource, externalId) to upsert.
  externalSource String?       @map("external_source") @db.VarChar(20)
  externalId     String?       @map("external_id") @db.VarChar(64)
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  options    ModifierSetOption[]
  attachedTo ItemOptionGroup[]

  @@unique([tenantId, externalSource, externalId])
  @@index([tenantId, position])
  @@map("modifier_sets")
}

model ModifierSetOption {
  id         String      @id @default(uuid()) @db.Uuid
  setId      String      @map("set_id") @db.Uuid
  set        ModifierSet @relation(fields: [setId], references: [id], onDelete: Cascade)
  name       String
  priceDelta Int         @default(0) @map("price_delta")
  // Explicit half-placement price (shekels) when the parent set has
  // customHalfPrice=true. NULL falls back to priceDelta. See ItemOption.
  halfPriceDelta Int?     @map("half_price_delta")
  isDefault  Boolean     @default(false) @map("is_default")
  available  Boolean     @default(true)
  imageUrl   String?     @map("image_url")
  position   Int         @default(0)
  // Provenance for bulk imports - scoped per parent set so the same source
  // option id can re-appear if the merchant has two imported sets.
  externalId String?     @map("external_id") @db.VarChar(64)

  @@unique([setId, externalId])
  @@index([setId, position])
  @@map("modifier_set_options")
}

// ─── Customer & Address ─────────────────────────────────────────

model Customer {
  id         String   @id @default(uuid()) @db.Uuid
  phone      String   @unique
  email      String?
  firstName  String   @default("") @map("first_name")
  lastName   String   @default("") @map("last_name")
  anonymized Boolean  @default(false)
  /// Explicit opt-in to marketing/promotional content (email or SMS).
  /// Defaults to false - the customer has to actively tick the consent
  /// checkbox during checkout / kiosk capture. Stays false unless the
  /// customer says yes; later opt-outs flip it back to false.
  marketingConsent Boolean @default(false) @map("marketing_consent")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  lastSeenAt DateTime @default(now()) @map("last_seen_at")

  addresses Address[]
  orders    Order[]
  reviews   Review[]
  apiKeys   ApiKey[]
  favorites Favorite[]

  @@map("customers")
}

model Address {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  label      String?
  street     String
  city       String
  apartment  String?
  floor      String?
  entrance   String?
  lat        Decimal? @db.Decimal(10, 7)
  lng        Decimal? @db.Decimal(10, 7)
  notes      String?
  isDefault  Boolean  @default(false) @map("is_default")

  orders Order[]

  @@index([customerId])
  @@map("addresses")
}

// ─── Orders ─────────────────────────────────────────────────────

model Order {
  id         String    @id @default(uuid()) @db.Uuid
  number     String
  tenantId   String    @map("tenant_id") @db.Uuid
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId   String    @map("branch_id") @db.Uuid
  branch     Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customerId String?   @map("customer_id") @db.Uuid
  customer   Customer? @relation(fields: [customerId], references: [id])

  status OrderStatus @default(pending)
  method OrderMethod @default(delivery)
  source OrderSource @default(direct)

  deliveryAddressId String?  @map("delivery_address_id") @db.Uuid
  deliveryAddress   Address? @relation(fields: [deliveryAddressId], references: [id])
  deliveryNotes     String?  @map("delivery_notes")

  scheduledFor DateTime? @map("scheduled_for")

  subtotal    Int @default(0)
  deliveryFee Int @default(0) @map("delivery_fee")
  serviceFee  Int @default(0) @map("service_fee")
  cutleryCount Int @default(0) @map("cutlery_count")
  cutleryFee   Int @default(0) @map("cutlery_fee")
  tip         Int @default(0)
  discount    Int @default(0)
  total       Int @default(0)

  paymentMethod   PaymentMethod @default(cash) @map("payment_method")
  paymentStatus   PaymentStatus @default(pending) @map("payment_status")
  paymentIntentId String?       @map("payment_intent_id")

  /// Provenance for orders ingested from an external marketplace (Wolt and
  /// friends). externalSource = "wolt"; externalId = the marketplace order
  /// id. The unique pair makes the order webhook idempotent - a retried
  /// delivery upserts instead of creating a duplicate order.
  externalSource String? @map("external_source") @db.VarChar(20)
  externalId     String? @map("external_id") @db.VarChar(64)

  /// Tax invoice / receipt landed via Grow's async invoice callback (the
  /// `invoiceNotifyUrl` we pass on createPaymentProcess). Both stay NULL
  /// for cash orders + for tenants without invoice generation enabled in
  /// their Grow control panel - UI degrades gracefully.
  invoiceNumber String? @map("invoice_number")
  invoiceUrl    String? @map("invoice_url")

  /// Set when the merchant taps the X icon on a Kanban card. The order
  /// stays in the DB + History view + still bills the customer
  /// normally - this only hides it from the active-orders board so the
  /// kitchen stops staring at a card that's gone stale ("חורג" timeout,
  /// duplicate, customer walked off, …). NULL = visible on the Kanban.
  kanbanHiddenAt DateTime? @map("kanban_hidden_at")

  courierId String?  @map("courier_id") @db.Uuid
  courier   Courier? @relation(fields: [courierId], references: [id])

  customerNotes         String? @map("customer_notes")
  customerPhoneSnap     String? @map("customer_phone_snap")
  customerFirstNameSnap String? @map("customer_first_name_snap")
  customerLastNameSnap  String? @map("customer_last_name_snap")
  customerEmailSnap     String? @map("customer_email_snap")
  /// When the customer ticked "I accept the terms" at checkout. Proof of
  /// consent for Grow payment-processor compliance.
  termsAcceptedAt       DateTime? @map("terms_accepted_at")

  estimatedReadyAt    DateTime? @map("estimated_ready_at")
  estimatedDeliveryAt DateTime? @map("estimated_delivery_at")

  createdAt           DateTime  @default(now()) @map("created_at")
  confirmedAt         DateTime? @map("confirmed_at")
  readyAt             DateTime? @map("ready_at")
  courierAssignedAt   DateTime? @map("courier_assigned_at")
  courierPickedUpAt   DateTime? @map("courier_picked_up_at")
  deliveredAt         DateTime? @map("delivered_at")
  cancelledAt         DateTime? @map("cancelled_at")

  cashCollected  Int?    @map("cash_collected")
  /// Change handed back to the customer on a cash sale. Independent of
  /// cashCollected so day-end can reconcile "drawer received - drawer paid out".
  cashChange     Int?    @map("cash_change")
  proofPhotoUrl  String? @map("proof_photo_url")

  /// Cashier who rang or settled this order (POS sales + counter-paid kiosk).
  /// NULL for direct/online flows. Drives the shift report.
  cashierId String?       @map("cashier_id") @db.Uuid
  cashier   MerchantUser? @relation("OrderCashier", fields: [cashierId], references: [id], onDelete: SetNull)
  /// Open POS shift that this order belongs to. Set the moment the cashier
  /// touches it (ring-up or cash-collected). NULL for non-POS orders.
  posShiftId String?   @map("pos_shift_id") @db.Uuid
  posShift   PosShift? @relation(fields: [posShiftId], references: [id], onDelete: SetNull)

  rating                  Int?
  reviewText              String?   @map("review_text")
  reviewPromptDismissedAt DateTime? @map("review_prompt_dismissed_at")

  items           OrderItem[]
  events          OrderEvent[]
  review          Review?
  pendingPayments PendingPayment[]
  paymentTxns     PaymentTransaction[]

  @@unique([tenantId, number])
  @@unique([tenantId, externalSource, externalId])
  @@index([tenantId, status, createdAt(sort: Desc)])
  @@index([customerId, createdAt(sort: Desc)])
  @@index([posShiftId])
  @@map("orders")
}

/// One cashier × one branch × one day = one shift. Opens with a cash
/// "float" (the drawer's starting balance), accumulates every paid-cash
/// order, optionally records mid-shift drawer drops in `cashOutNotes`,
/// closes with a counted `closingFloat` and a computed `expectedCash`
/// - the variance is the day-end report.
model PosShift {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId     String   @map("branch_id") @db.Uuid
  branch       Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  cashierId    String   @map("cashier_id") @db.Uuid
  cashier      MerchantUser @relation(fields: [cashierId], references: [id], onDelete: Restrict)

  openedAt     DateTime @default(now()) @map("opened_at")
  closedAt     DateTime? @map("closed_at")

  openingFloat Int      @map("opening_float")
  closingFloat Int?     @map("closing_float")
  /// Computed at close: openingFloat + Σ(paid-cash sales) − Σ(cashOut). Persisted
  /// so the day-end summary survives later edits to underlying orders.
  expectedCash Int?     @map("expected_cash")
  /// Array of `{ ts, amount, reason }` entries written by `cash-out`. Each
  /// entry is also reflected in `expectedCash` at close time.
  cashOutNotes Json     @default("[]") @map("cash_out_notes")

  orders       Order[]

  @@unique([cashierId, openedAt])
  @@index([tenantId, branchId, openedAt(sort: Desc)])
  @@index([cashierId, closedAt])
  @@map("pos_shifts")
}

model OrderItem {
  id         String    @id @default(uuid()) @db.Uuid
  orderId    String    @map("order_id") @db.Uuid
  order      Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String?   @map("menu_item_id") @db.Uuid
  menuItem   MenuItem? @relation(fields: [menuItemId], references: [id])

  nameSnapshot String @map("name_snapshot")
  quantity     Int    @default(1)
  unitPrice    Int    @map("unit_price")
  totalPrice   Int    @map("total_price")

  sizeId       String? @map("size_id") @db.Uuid
  sizeSnapshot String? @map("size_snapshot")

  selectedOptions Json @default("[]") @map("selected_options")

  source OrderItemSource @default(menu)

  notes String?

  // Per-item prep toggle - the kitchen ticks off each line as it
  // goes out (todo-list style on the Kanban card). NULL = not yet
  // started. The order's status field is still the authoritative
  // "ready" signal; this is just visual sub-state so the cook
  // doesn't lose track of "what's still left on this ticket".
  preparedAt DateTime? @map("prepared_at")

  reviewItems ReviewItem[]

  @@index([orderId])
  @@map("order_items")
}

model OrderEvent {
  id        String   @id @default(uuid()) @db.Uuid
  orderId   String   @map("order_id") @db.Uuid
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type      String
  payload   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([orderId, createdAt])
  @@index([createdAt])
  @@map("order_events")
}

// ─── Cart (server-side, per customer/tenant) ────────────────────

model Cart {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String?  @map("customer_id") @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  sessionId  String?  @unique @map("session_id")
  couponCode String?  @map("coupon_code")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  items CartItem[]

  @@index([customerId, tenantId])
  @@map("carts")
}

model CartItem {
  id              String  @id @default(uuid()) @db.Uuid
  cartId          String  @map("cart_id") @db.Uuid
  cart            Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  menuItemId      String  @map("menu_item_id") @db.Uuid
  quantity        Int     @default(1)
  sizeId          String? @map("size_id") @db.Uuid
  selectedOptions Json    @default("[]") @map("selected_options")
  notes           String?

  @@index([cartId])
  @@map("cart_items")
}

// ─── Couriers & Reviews ─────────────────────────────────────────

model Courier {
  id              String         @id @default(uuid()) @db.Uuid
  tenantId        String         @map("tenant_id") @db.Uuid
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId        String?        @map("branch_id") @db.Uuid
  branch          Branch?        @relation(fields: [branchId], references: [id])
  name            String
  phone           String
  email           String?        @unique
  pinHash         String?        @map("pin_hash")
  vehicle         CourierVehicle @default(scooter)
  status          CourierStatus  @default(offline)
  currentLat      Decimal?       @map("current_lat") @db.Decimal(10, 7)
  currentLng      Decimal?       @map("current_lng") @db.Decimal(10, 7)
  currentOrderId  String?        @map("current_order_id") @db.Uuid
  maxConcurrent   Int            @default(3) @map("max_concurrent")
  cashOnHand      Int            @default(0) @map("cash_on_hand")
  tipsOnHand      Int            @default(0) @map("tips_on_hand")
  tipsOwed        Int            @default(0) @map("tips_owed")
  active          Boolean        @default(true)
  lastSeenAt      DateTime?      @map("last_seen_at")
  ratingAvg       Decimal        @default(0) @map("rating_avg") @db.Decimal(3, 2)
  deliveriesToday Int            @default(0) @map("deliveries_today")
  createdAt       DateTime       @default(now()) @map("created_at")

  orders   Order[]
  sessions CourierSession[]
  magicLinks CourierMagicLinkToken[]
  cashSettlements CashSettlement[]
  pushSubscriptions CourierPushSubscription[]

  @@index([branchId, status])
  @@map("couriers")
}

model CourierPushSubscription {
  id         String    @id @default(uuid()) @db.Uuid
  courierId  String    @map("courier_id") @db.Uuid
  courier    Courier   @relation(fields: [courierId], references: [id], onDelete: Cascade)
  endpoint   String    @unique
  p256dh     String
  auth       String
  userAgent  String?   @map("user_agent")
  createdAt  DateTime  @default(now()) @map("created_at")
  lastSeenAt DateTime? @map("last_seen_at")

  @@index([courierId])
  @@map("courier_push_subscriptions")
}

model CashSettlement {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courierId   String   @map("courier_id") @db.Uuid
  courier     Courier  @relation(fields: [courierId], references: [id], onDelete: Cascade)
  amount      Int
  settledBy   String   @map("settled_by")
  settledById String?  @map("settled_by_id") @db.Uuid
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([courierId, createdAt(sort: Desc)])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("cash_settlements")
}

model CourierSession {
  id        String    @id @default(uuid()) @db.Uuid
  courierId String    @map("courier_id") @db.Uuid
  courier   Courier   @relation(fields: [courierId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash")
  device    String?
  ip        String?
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  @@index([courierId, createdAt(sort: Desc)])
  @@map("courier_sessions")
}

model CourierMagicLinkToken {
  id        String    @id @default(uuid()) @db.Uuid
  courierId String    @map("courier_id") @db.Uuid
  courier   Courier   @relation(fields: [courierId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([courierId, createdAt(sort: Desc)])
  @@map("courier_magic_link_tokens")
}

model Review {
  id         String       @id @default(uuid()) @db.Uuid
  tenantId   String       @map("tenant_id") @db.Uuid
  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderId    String       @unique @map("order_id") @db.Uuid
  order      Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId String       @map("customer_id") @db.Uuid
  customer   Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  rating     Int
  text       String?
  replyText  String?      @map("reply_text")
  replyAt    DateTime?    @map("reply_at")
  status     ReviewStatus @default(visible)
  createdAt  DateTime     @default(now()) @map("created_at")

  items ReviewItem[]

  @@index([tenantId, createdAt(sort: Desc)])
  @@map("reviews")
}

model SmsLog {
  id           String             @id @default(uuid()) @db.Uuid
  tenantId     String             @map("tenant_id") @db.Uuid
  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  to           String
  sender       String
  body         String
  // "sms" or "whatsapp". Both channels write to this single audit log,
  // since the credit pool, balance, and history UI are unified.
  channel      String             @default("sms")
  // What we're sending - e.g. "review_reminder", "order_status", etc.
  kind         String             @default("generic")
  // Free-form reference (e.g. orderId for a review reminder) for idempotency
  // and observability. Not enforced as FK because senders may be diverse.
  refKind      String?            @map("ref_kind")
  refId        String?            @map("ref_id")
  status       NotificationStatus @default(pending)
  providerCode Int?               @map("provider_code")
  providerMsg  String?            @map("provider_msg")
  sentAt       DateTime?          @map("sent_at")
  deliveredAt  DateTime?          @map("delivered_at")
  createdAt    DateTime           @default(now()) @map("created_at")

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([refKind, refId])
  @@map("sms_logs")
}

model EmailLog {
  id          String             @id @default(uuid()) @db.Uuid
  tenantId    String?            @map("tenant_id") @db.Uuid
  tenant      Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  to          String
  fromName    String             @default("") @map("from_name")
  subject     String
  body        String
  kind        String             @default("generic")
  refKind     String?            @map("ref_kind")
  refId       String?            @map("ref_id")
  status      NotificationStatus @default(pending)
  providerId  String?            @map("provider_id")
  providerMsg String?            @map("provider_msg")
  sentAt      DateTime?          @map("sent_at")
  createdAt   DateTime           @default(now()) @map("created_at")

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([refKind, refId])
  @@map("email_logs")
}

model ReviewItem {
  id          String    @id @default(uuid()) @db.Uuid
  reviewId    String    @map("review_id") @db.Uuid
  review      Review    @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  // The order line this rating refers to. Cascade-delete with the review;
  // if the order is deleted, the parent Review cascades too.
  orderItemId String    @map("order_item_id") @db.Uuid
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  // Denormalized menu_item_id for fast per-product aggregation. Nullable
  // because OrderItem.menuItemId is nullable (legacy/free items).
  menuItemId  String?   @map("menu_item_id") @db.Uuid
  menuItem    MenuItem? @relation(fields: [menuItemId], references: [id])
  rating      Int
  text        String?
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([menuItemId, createdAt(sort: Desc)])
  @@index([reviewId])
  @@map("review_items")
}

// ─── Auth ───────────────────────────────────────────────────────

model MerchantUser {
  id                String                    @id @default(uuid()) @db.Uuid
  tenantId          String?                   @map("tenant_id") @db.Uuid
  tenant            Tenant?                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email             String                    @unique
  passwordHash      String                    @map("password_hash")
  name              String
  phone             String?                   @map("phone")
  // Normalised E.164 copy of `phone` (+9725XXXXXXXX), kept in sync on write.
  // This is the lookup key for passwordless WhatsApp-OTP login - `phone` is
  // stored in whatever shape the merchant typed (dashes, spaces, 05.. or
  // +972..), so it can't be matched directly. NOT unique: a few owners run
  // more than one store off the same number.
  phoneE164         String?                   @map("phone_e164")
  role              UserRole                  @default(owner)
  branches          String[]                  @default([])
  // Cashier users are pinned to one branch (their POS terminal). For other
  // roles this is informational only - gating is via `branches` above.
  branchId          String?                   @map("branch_id") @db.Uuid
  branch            Branch?                   @relation("MerchantUserBranch", fields: [branchId], references: [id], onDelete: SetNull)
  tfaEnabled        Boolean                   @default(false) @map("tfa_enabled")
  tfaSecret         String?                   @map("tfa_secret")
  lastLoginAt       DateTime?                 @map("last_login_at")
  emailVerifiedAt   DateTime?                 @map("email_verified_at")
  createdAt         DateTime                  @default(now()) @map("created_at")
  passwordResets    PasswordResetToken[]
  emailVerifications EmailVerificationToken[]
  pushSubscriptions  MerchantUserPushSubscription[]
  expoPushTokens     MerchantExpoPushToken[]
  posShifts         PosShift[]
  ordersAsCashier   Order[] @relation("OrderCashier")

  @@index([tenantId])
  @@index([branchId])
  @@index([phoneE164])
  @@map("merchant_users")
}

model MerchantUserPushSubscription {
  id         String       @id @default(uuid()) @db.Uuid
  userId     String       @map("user_id") @db.Uuid
  user       MerchantUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId   String?      @map("tenant_id") @db.Uuid
  endpoint   String       @unique
  p256dh     String
  auth       String
  userAgent  String?      @map("user_agent")
  createdAt  DateTime     @default(now()) @map("created_at")
  lastSeenAt DateTime?    @map("last_seen_at")

  @@index([userId])
  @@index([tenantId])
  @@map("merchant_user_push_subscriptions")
}

/// Expo push tokens for the native merchant app. Unlike web-push
/// (endpoint/p256dh/auth) above, the native app registers a single
/// `ExponentPushToken[...]` string; delivery goes through Expo's push
/// service (exp.host). Tokens that Expo reports as DeviceNotRegistered
/// are deleted so we stop retrying them.
model MerchantExpoPushToken {
  id         String       @id @default(uuid()) @db.Uuid
  userId     String       @map("user_id") @db.Uuid
  user       MerchantUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId   String?      @map("tenant_id") @db.Uuid
  token      String       @unique
  platform   String?
  deviceName String?      @map("device_name")
  createdAt  DateTime     @default(now()) @map("created_at")
  lastSeenAt DateTime?    @map("last_seen_at")

  @@index([userId])
  @@index([tenantId])
  @@map("merchant_expo_push_tokens")
}

/// Short-lived tokens for the "forgot password" flow. We email a one-time
/// URL containing the raw token; the DB only stores its SHA-256 hash, so a
/// stolen DB row can't be redeemed. Tokens expire fast (default 30 min) and
/// are single-use (usedAt is set on success).
model PasswordResetToken {
  id        String       @id @default(uuid()) @db.Uuid
  userId    String       @map("user_id") @db.Uuid
  user      MerchantUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String       @unique @map("token_hash")
  expiresAt DateTime     @map("expires_at")
  usedAt    DateTime?    @map("used_at")
  createdAt DateTime     @default(now()) @map("created_at")

  @@index([userId, createdAt(sort: Desc)])
  @@map("password_reset_tokens")
}

/// Email verification tokens. Created on signup and whenever the merchant
/// clicks "send again" from the verification banner. We hash the token at
/// rest (same pattern as PasswordResetToken) so a leaked DB doesn't grant
/// account access. Tokens are single-use - `usedAt` is set on first hit
/// to make replay impossible.
model EmailVerificationToken {
  id        String       @id @default(uuid()) @db.Uuid
  userId    String       @map("user_id") @db.Uuid
  user      MerchantUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String       @unique @map("token_hash")
  expiresAt DateTime     @map("expires_at")
  usedAt    DateTime?    @map("used_at")
  createdAt DateTime     @default(now()) @map("created_at")

  @@index([userId, createdAt(sort: Desc)])
  @@map("email_verification_tokens")
}

model OtpCode {
  id        String    @id @default(uuid()) @db.Uuid
  phone     String
  codeHash  String    @map("code_hash")
  attempts  Int       @default(0)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([phone, createdAt(sort: Desc)])
  @@map("otp_codes")
}

/// Platform-wide singleton settings, edited by platform admins from
/// `/admin/settings`. The `id` is hard-coded to "singleton" so there is
/// exactly one row - we upsert it from the API. New global defaults
/// (fallback tokens, feature flags, etc.) get added as new columns here.
model PlatformSettings {
  id                        String   @id @default("singleton")
  /// Fallback iBot Chat token used when a tenant has no own credentials.
  /// Tenants who paste their own token+instance_id in dashboard settings
  /// take precedence (per-merchant WhatsApp number).
  whatsappDefaultToken      String?  @map("whatsapp_default_token")
  whatsappDefaultInstanceId String?  @map("whatsapp_default_instance_id")
  updatedAt                 DateTime @updatedAt @map("updated_at")
  createdAt                 DateTime @default(now()) @map("created_at")

  @@map("platform_settings")
}

model ApiKey {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String?   @map("tenant_id") @db.Uuid
  tenant     Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId String?   @map("customer_id") @db.Uuid
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name       String
  hash       String    @unique
  prefix     String
  scopes     String[]  @default([])
  lastUsedAt DateTime? @map("last_used_at")
  expiresAt  DateTime? @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("api_keys")
}

// ─── Plans & Billing ────────────────────────────────────────────

model Plan {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  priceMonthly Int      @map("price_monthly")
  features     Json     @default("{}")
  orderLimit   Int?     @map("order_limit")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")

  tenants       Tenant[]
  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                 String             @id @default(uuid()) @db.Uuid
  tenantId           String             @unique @map("tenant_id") @db.Uuid
  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId             String             @map("plan_id") @db.Uuid
  plan               Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)
  status             SubscriptionStatus @default(trial)
  currentPeriodStart DateTime           @map("current_period_start")
  currentPeriodEnd   DateTime           @map("current_period_end")
  paymentMethodId    String?            @map("payment_method_id")
  cancelAtPeriodEnd  Boolean            @default(false) @map("cancel_at_period_end")
  createdAt          DateTime           @default(now()) @map("created_at")

  @@map("subscriptions")
}

// ─── Coupons & Notifications ────────────────────────────────────

model Coupon {
  id               String          @id @default(uuid()) @db.Uuid
  tenantId         String          @map("tenant_id") @db.Uuid
  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code             String
  description      String          @default("")
  type             CouponType      @default(percent)
  value            Int
  minOrder         Int?            @map("min_order")
  maxDiscount      Int?            @map("max_discount")
  usageLimit       Int?            @map("usage_limit")
  usageCount       Int             @default(0) @map("usage_count")
  perCustomerLimit Int?            @map("per_customer_limit")
  validFrom        DateTime        @default(now()) @map("valid_from")
  validUntil       DateTime?       @map("valid_until")
  active           Boolean         @default(true)
  // Targeting: by default applies to the whole order. Restrict to a single
  // category or to a list of specific items to enable promos like
  // "20% off all pizzas" or "₪10 off a chosen drink." Discount is computed
  // server-side on just the matching lines (not the whole subtotal).
  appliesTo        CouponAppliesTo @default(all) @map("applies_to")
  categoryId       String?         @map("category_id") @db.Uuid
  itemIds          String[]        @default([]) @map("item_ids") @db.Uuid

  @@unique([tenantId, code])
  @@index([tenantId, active])
  @@map("coupons")
}

model Notification {
  id            String        @id @default(uuid()) @db.Uuid
  recipientType RecipientType @map("recipient_type")
  recipientId   String        @map("recipient_id") @db.Uuid
  type          String
  title         String
  body          String
  data          Json          @default("{}")
  readAt        DateTime?     @map("read_at")
  channels      String[]      @default([])
  createdAt     DateTime      @default(now()) @map("created_at")

  @@index([recipientType, recipientId, createdAt(sort: Desc)])
  @@map("notifications")
}

// ─── Webhooks (outbound) ────────────────────────────────────────

model WebhookEndpoint {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  url       String
  secret    String
  events    String[] @default([])
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  deliveries WebhookDelivery[]

  @@index([tenantId, active])
  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id              String                @id @default(uuid()) @db.Uuid
  endpointId      String                @map("endpoint_id") @db.Uuid
  endpoint        WebhookEndpoint       @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  eventType       String                @map("event_type")
  payload         Json                  @default("{}")
  status          WebhookDeliveryStatus @default(pending)
  attempts        Int                   @default(0)
  lastAttemptAt   DateTime?             @map("last_attempt_at")
  nextRetryAt     DateTime?             @map("next_retry_at")
  responseCode    Int?                  @map("response_code")
  responseBody    String?               @map("response_body")
  responseHeaders Json?                 @map("response_headers")
  createdAt       DateTime              @default(now()) @map("created_at")

  @@index([status, nextRetryAt])
  @@index([endpointId, createdAt(sort: Desc)])
  @@map("webhook_deliveries")
}

/// Idempotency-Key support for non-GET endpoints called by external systems
/// (POS, custom integrations). The first request stores its response; later
/// requests with the same (tenantId, key) get the cached response back
/// instead of executing the side effect twice.
model IdempotencyRecord {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key          String
  method       String
  path         String
  requestHash  String   @map("request_hash")
  statusCode   Int      @map("status_code")
  responseBody String   @map("response_body") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  expiresAt    DateTime @map("expires_at")

  @@unique([tenantId, key])
  @@index([expiresAt])
  @@map("idempotency_records")
}

// ─── Payments ───────────────────────────────────────────────────

/// Per-tenant credentials for a payment provider.
/// For Grow: credentials contains { userId, pageCode? }. The platform-level
/// apiKey + default pageCode live in env (GROW_API_KEY, GROW_PAGE_CODE).
model PaymentProviderConfig {
  id                        String          @id @default(uuid()) @db.Uuid
  tenantId                  String          @map("tenant_id") @db.Uuid
  tenant                    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider                  PaymentProvider
  credentials               Json            @default("{}")
  settings                  Json            @default("{}")
  testMode                  Boolean         @default(true) @map("test_mode")
  isActive                  Boolean         @default(false) @map("is_active")
  /// Per-tenant Apple Pay domain-association file content. Only used when the
  /// tenant serves checkout from a custom domain (Tenant.customDomain). Issued
  /// by Grow per domain. For tenants on the platform domain, leave NULL - the
  /// /.well-known/ route falls back to APPLE_PAY_DOMAIN_ASSOCIATION_(DEV|PROD).
  applePayDomainAssociation String?         @map("apple_pay_domain_association") @db.Text
  createdAt                 DateTime        @default(now()) @map("created_at")
  updatedAt                 DateTime        @updatedAt @map("updated_at")

  @@unique([tenantId, provider])
  @@map("payment_provider_configs")
}

/// Created when /pay/initiate is called. Lives until the S2S callback arrives
/// or the link expires (~10 min for Grow). providerRequestId == Grow processId.
model PendingPayment {
  id                String               @id @default(uuid()) @db.Uuid
  tenantId          String               @map("tenant_id") @db.Uuid
  tenant            Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderId           String               @map("order_id") @db.Uuid
  order             Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderReference    String               @map("order_reference") // round-trips in Grow's cField1
  provider          PaymentProvider
  amount            Int // אגורות (matches Order.total)
  currency          String               @default("ILS")
  status            PendingPaymentStatus @default(pending)
  providerRequestId String?              @map("provider_request_id") // Grow processId
  authCode          String?              @map("auth_code") // Grow SDK authCode (debug only)
  providerResponse  Json?                @map("provider_response")
  createdAt         DateTime             @default(now()) @map("created_at")
  confirmedAt       DateTime?            @map("confirmed_at")
  expiresAt         DateTime?            @map("expires_at")

  transactions PaymentTransaction[]

  @@index([orderReference])
  @@index([providerRequestId])
  @@index([tenantId, status, createdAt(sort: Desc)])
  @@map("pending_payments")
}

// Kiosk-card pre-checkout. Holds the cart snapshot while Grow processes
// the payment so the Order row only materializes once payment confirms.
// Avoids the "zombie order" problem where unpaid kiosk attempts leave
// stale rows in the orders table. Cash kiosk orders skip this - they
// go straight into Order at status=pending and the cashier confirms.
model KioskPendingCheckout {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Snapshot of the full create-order input so the callback can replay
  // it verbatim through createOrder() on payment success.
  cartData     Json     @map("cart_data")
  // Pre-computed total in agorot for the Grow initiate-payment call.
  // Locked in at create time so a price change between create and
  // materialize doesn't cause a charge/order mismatch.
  amount       Int

  // The Order row the callback materialized once payment confirmed.
  orderId      String?  @map("order_id") @db.Uuid

  status       String   @default("pending") // pending | completed | abandoned
  growProcessId String? @map("grow_process_id")
  authCode     String?  @map("auth_code")
  providerResponse Json? @map("provider_response")

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt       @map("updated_at")
  expiresAt    DateTime @map("expires_at")

  @@index([tenantId, status])
  @@map("kiosk_pending_checkouts")
}

/// Final transaction record after a successful S2S callback. Stores the
/// transactionToken needed for refunds.
model PaymentTransaction {
  id                    String                   @id @default(uuid()) @db.Uuid
  tenantId              String                   @map("tenant_id") @db.Uuid
  tenant                Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderId               String                   @map("order_id") @db.Uuid
  order                 Order                    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  pendingPaymentId      String?                  @map("pending_payment_id") @db.Uuid
  pendingPayment        PendingPayment?          @relation(fields: [pendingPaymentId], references: [id])
  provider              PaymentProvider
  status                PaymentTransactionStatus @default(success)
  amount                Int // אגורות
  currency              String                   @default("ILS")
  providerTransactionId String                   @map("provider_transaction_id") // Grow transactionId
  providerRequestId     String?                  @map("provider_request_id") // Grow processId
  providerToken         String?                  @map("provider_token") // Grow transactionToken (refund)
  approvalNumber        String?                  @map("approval_number") // Grow asmachta
  cardBrand             String?                  @map("card_brand")
  cardLastFour          String?                  @map("card_last_four")
  refundedAmount        Int                      @default(0) @map("refunded_amount")
  providerResponse      Json?                    @map("provider_response")
  createdAt             DateTime                 @default(now()) @map("created_at")

  @@unique([provider, providerTransactionId])
  @@index([orderId])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("payment_transactions")
}

enum CampaignKind {
  popup
  banner
}

enum CampaignStyle {
  image
  text
}

model Campaign {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  kind     CampaignKind  @default(popup)
  // For kind=banner only. popups are always rendered as their image.
  style    CampaignStyle @default(image)
  title    String        @db.VarChar(120)
  // Optional second line, only used by text-style banners.
  subtitle String?       @db.VarChar(160)
  // Icon + color slugs reused from lib/category-style.ts. Only text-style
  // banners read these; popups and image banners ignore them.
  icon     String?       @db.VarChar(40)
  color    String?       @db.VarChar(40)
  // Required for popups and image-style banners; optional (and unused) for
  // text-style banners. Enforced at the API layer, not at the DB level.
  imageUrl String?       @map("image_url")
  isActive Boolean       @default(true) @map("is_active")
  linkUrl  String?       @map("link_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId, kind, isActive, updatedAt(sort: Desc)])
  @@map("campaigns")
}

model Notice {
  id         String      @id @default(uuid()) @db.Uuid
  tenantId   String      @map("tenant_id") @db.Uuid
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  scope      NoticeScope @default(store)
  categoryId String?     @map("category_id") @db.Uuid
  category   MenuCategory? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  itemId     String?     @map("item_id") @db.Uuid
  item       MenuItem?   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  kind       NoticeKind  @default(info)
  title      String      @db.VarChar(120)
  body       String?     @db.VarChar(500)
  icon       String?     @db.VarChar(40)
  active     Boolean     @default(true)
  position   Int         @default(0)
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  @@index([tenantId, scope, active, position])
  @@index([categoryId])
  @@index([itemId])
  @@map("notices")
}

// Records a one-shot menu import from a Wolt venue. The flow is:
// (1) merchant pastes a Wolt URL → server resolves venue_id, fetches the
//     menu JSON, writes a row with status=preview and stows the raw JSON
//     in rawMenu so the commit step doesn't have to re-fetch and so we
//     have an audit trail for debugging.
// (2) merchant confirms in the UI → server reads rawMenu, creates/updates
//     MenuCategory + ModifierSet + MenuItem rows keyed by (tenantId,
//     externalSource='wolt', externalId=<wolt id>), downloads images to
//     R2, flips status to committed (or failed + errors[]).
//
// The most recent row per tenant gates re-import frequency - we don't
// need a separate field on Tenant.
model WoltImport {
  id                 String           @id @default(uuid()) @db.Uuid
  tenantId           String           @map("tenant_id") @db.Uuid
  tenant             Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sourceUrl          String           @map("source_url")
  venueId            String           @map("venue_id") @db.VarChar(64)
  venueName          String           @map("venue_name")
  status             WoltImportStatus
  // Counts captured from the parsed menu and again after commit, so the
  // UI can show "23/47 פריטים יובאו" without recomputing.
  categoriesTotal    Int              @default(0) @map("categories_total")
  itemsTotal         Int              @default(0) @map("items_total")
  categoriesImported Int              @default(0) @map("categories_imported")
  itemsImported      Int              @default(0) @map("items_imported")
  imagesUploaded     Int              @default(0) @map("images_uploaded")
  // Array of { context: string, message: string } for partial failures.
  errors             Json?
  // Raw Wolt /v4/venues/{id}/menu response, kept for the lifetime of the
  // row (~megabyte per import - tolerable). Lets the commit step run
  // without re-fetching, and helps when debugging mapping issues.
  rawMenu            Json?            @map("raw_menu")
  // Raw venue payload scraped from the Wolt HTML page (name, address,
  // phone, hours, cover/logo URLs, description). Kept separately from
  // rawMenu so the commit step can re-apply venue info without
  // touching the menu pipeline. Same audit-trail rationale as rawMenu.
  rawVenue           Json?            @map("raw_venue")
  createdAt          DateTime         @default(now()) @map("created_at")
  committedAt        DateTime?        @map("committed_at")
  // Audit trail: who triggered the commit and which version of the Wolt
  // import terms was in effect at that moment. Stamped server-side so it
  // can't be spoofed by the client - evidence the merchant requested it.
  importedByUserId   String?          @map("imported_by_user_id")
  termsVersion       String?          @map("terms_version")

  @@index([tenantId, createdAt(sort: Desc)])
  @@map("wolt_imports")
}

enum MenuFileImportSource {
  pdf
  image
}

/// First-party storefront visit tracking. One row per (tenant, visitor,
/// Israel-day), with `visits` counting tab-session opens that day. The
/// visitor is identified by the `qf_vid` first-party cookie; `customerId`
/// is stamped when the visitor is a logged-in customer. Merchants viewing
/// their own storefront are NOT recorded. Powers the dashboard's
/// "visitors today" / "unique customers" metrics without depending on
/// GA/Meta (which are third-party + ad-blocked).
model StorefrontVisit {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  visitorId  String   @map("visitor_id")
  customerId String?  @map("customer_id") @db.Uuid
  // Israel-local midnight instant for the day this visit belongs to.
  day        DateTime
  visits     Int      @default(1)
  createdAt  DateTime @default(now()) @map("created_at")
  lastAt     DateTime @default(now()) @map("last_at")

  @@unique([tenantId, visitorId, day])
  @@index([tenantId, day])
  @@map("storefront_visits")
}

/// AI-extracted menu import from an uploaded PDF or photo. Mirrors the
/// Wolt import lifecycle (preview → merchant confirms/edits → commit) but
/// the source is a file the merchant uploads rather than a Wolt URL. The
/// extraction (categories / items / modifiers) is produced by Gemini and
/// stashed in `extraction`; the merchant edits it client-side and the
/// edited tree is what `commit` persists.
model MenuFileImport {
  id                 String               @id @default(uuid()) @db.Uuid
  tenantId           String               @map("tenant_id") @db.Uuid
  tenant             Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  source             MenuFileImportSource
  status             WoltImportStatus
  fileName           String               @map("file_name")
  categoriesTotal    Int                  @default(0) @map("categories_total")
  itemsTotal         Int                  @default(0) @map("items_total")
  categoriesImported Int                  @default(0) @map("categories_imported")
  itemsImported      Int                  @default(0) @map("items_imported")
  // Array of { context, message } for partial failures during commit.
  errors             Json?
  // The raw Gemini extraction (normalized ExtractedMenu shape), kept for
  // audit + so a re-open of the preview can re-render without re-billing
  // a model call.
  extraction         Json?
  // Which model produced the extraction (e.g. "gemini-2.5-flash").
  model              String?
  createdAt          DateTime             @default(now()) @map("created_at")
  committedAt        DateTime?            @map("committed_at")
  importedByUserId   String?              @map("imported_by_user_id")

  @@index([tenantId, createdAt(sort: Desc)])
  @@map("menu_file_imports")
}

/// Per-tenant Wolt Marketplace connection established via SSIO (OAuth 2.0).
/// One row per connected Wolt venue. Holds the rotating access/refresh
/// tokens so the order webhook + Order API calls (accept/reject/ready) can
/// authenticate on behalf of the merchant. Tokens are short-lived: access
/// ~1h, refresh ~30d single-use - see lib/wolt/oauth.ts.
model WoltConnection {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  venueId         String   @map("venue_id") @db.VarChar(64)
  status          String   @default("active")
  accessToken     String?  @map("access_token")
  refreshToken    String?  @map("refresh_token")
  tokenExpiresAt  DateTime? @map("token_expires_at")
  lastOrderAt     DateTime? @map("last_order_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, venueId])
  @@index([venueId])
  @@map("wolt_connections")
}

model GrowLead {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String?  @map("tenant_id") @db.Uuid
  tenant         Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  businessNumber String   @map("business_number")
  businessName   String   @map("business_name")
  phone          String
  website        String?
  status         String   @default("pending")
  airtableRowId  String?  @map("airtable_row_id")
  error          String?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt(sort: Desc)])
  @@map("grow_leads")
}

model MarketingLead {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  restaurant  String?
  phone       String?
  email       String
  message     String?
  source      String   @default("unknown")
  ip          String?
  emailStatus String?  @map("email_status")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([createdAt(sort: Desc)])
  @@map("marketing_leads")
}
